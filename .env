# =============================================================
#  YouCaps — Omgevingsvariabelen (VOORBEELD)
#  Kopieer dit bestand naar ".env" en vul de waarden in.
#  Commit NOOIT het echte .env bestand!
# =============================================================

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-api03-VERVANG-DIT-MET-JE-ECHTE-SLEUTEL

# --- Applicatie ---
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=VERVANG-DIT-MET-EEN-WILLEKEURIGE-STRING-VAN-64-TEKENS
APP_VERSION=0.3.0
DEBUG=true

# --- Database ---
# Ontwikkeling: SQLite (geen extra installatie nodig)
DATABASE_URL=sqlite:///./backend/db/youcaps.db

# Productie: PostgreSQL (uncomment en vul in)
# DATABASE_URL=postgresql://gebruiker:wachtwoord@localhost:5432/youcaps

# --- CORS (toegestane frontend origins, komma-gescheiden) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8000

# Regex voor dynamische tunnel-URLs (VS Code Dev Tunnels, ngrok, cloudflared).
# Laat leeg om uit te schakelen.
ALLOWED_ORIGIN_REGEX=https://.*\.devtunnels\.ms|https://.*\.ngrok-free\.app|https://.*\.ngrok\.io|https://.*\.trycloudflare\.com

# --- Rate Limiting ---
RATE_LIMIT_AI_CALLS=10/minute   # max AI-aanroepen (legacy text-scan) per gebruiker per minuut
RATE_LIMIT_SCAN=10/minute       # max foto-scans per IP per minuut
RATE_LIMIT_GLOBAL=60/minute     # globale fallback per IP

# --- Knowledge Base ---
KNOWLEDGE_BASE_PATH=backend/db/knowledge_base.json

# --- Vision Scanner (Fase 3) ---
VISION_MODEL=claude-haiku-4-5-20251001   # Anthropic vision-capable model
VISION_MAX_TOKENS=1500
VISION_TEMPERATURE=0.0
VISION_TIMEOUT_SECONDS=30
VISION_MAX_RETRIES=3

# --- Image Upload limieten ---
MAX_UPLOAD_MB=10                 # harde bovengrens voor één foto-upload
IMAGE_MAX_DIMENSION=1568         # langste zijde na resize (px)
IMAGE_MIN_DIMENSION=200          # minimaal acceptabele zijde (px)

# --- Matching engine drempels ---
MATCH_STRONG_THRESHOLD=0.85      # ≥ deze score: zekere match
MATCH_WEAK_THRESHOLD=0.65        # ≥ deze score: zwakke match (UI markeert)

# =============================================================
# --- Fase 4: Oura-integratie (wearable koppeling) ---
# Zie README.md → "Wearable-integratie" voor setup-instructies.
# =============================================================

# Oura Cloud OAuth (maak app aan op cloud.ouraring.com/developer)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8000/api/oura/callback

# Supabase project (EU-region aanbevolen: eu-central-1 of eu-west-1)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM encryptie-sleutel voor OAuth tokens
# Genereer met: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Frontend URL voor redirect na OAuth (niet aanpassen in dev)
FRONTEND_URL=http://localhost:5173
